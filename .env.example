# Required: PostgreSQL connection string
# Example: DATABASE_URL=postgresql://user:password@localhost:5432/intelivox
DATABASE_URL=

# Auth / session
# Secret used to sign session tokens. MUST be set to a long random value in production.
SECRET_KEY=
# Minutes a session token stays valid (sliding window, refreshed by the client).
TOKEN_TTL_MINUTES=20
# Generic password assigned to newly created users (forced change on first login).
GENERIC_PASSWORD=ChangeMe123!
# Name of the httpOnly auth cookie.
AUTH_COOKIE_NAME=access_token
# Set to true in production (HTTPS only).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax